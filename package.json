    "@nestjs/platform-express": "10.4.22",
    "@prisma/client": "5.22.0",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.22",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.2",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
