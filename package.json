{
  "name": "omnichat-saas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "api:build": "tsc -p apps/api/tsconfig.json",
    "api:deploy:build": "npx prisma generate && npx prisma migrate deploy && npm run prisma:seed && npm run api:build",
    "api:start": "npx prisma migrate deploy && node apps/api/dist/src/main.js",
    "api:start:prod": "npm run api:start",
    "api:test": "jest --config apps/api/jest.config.cjs",
    "api:test:cov": "jest --config apps/api/jest.config.cjs --coverage",
    "api:test:e2e": "jest --config apps/api/jest-e2e.config.cjs --runInBand",
    "api:typecheck": "tsc -p apps/api/tsconfig.json --noEmit",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up -d",
    "lint": "npm run api:typecheck && npm run ui:typecheck && npm run web:typecheck",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev --name init-stage1",
    "prisma:seed": "prisma db seed",
    "prisma:resolve:enable-ai-scenarios": "node scripts/resolve-enable-ai-scenarios-migration.mjs",
    "test": "npm run api:test && npm run web:test",
    "test:cov": "npm run api:test:cov",
    "ui:test": "jest --config apps/web/jest.config.cjs packages/ui",
    "ui:typecheck": "tsc -p packages/ui/tsconfig.json --noEmit",
    "web:build": "next build apps/web",
    "web:lint": "npm run web:typecheck",
    "web:test": "jest --config apps/web/jest.config.cjs",
    "web:typecheck": "tsc -p apps/web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "5.22.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.78.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "next": "^15.5.19",
    "otplib": "^13.4.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "0.2.2",
    "resend": "^6.12.4",
    "rxjs": "7.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.2",
    "@types/passport-jwt": "4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "6.0.2",
    "autoprefixer": "^10.4.22",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
