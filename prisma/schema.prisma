enum BroadcastType {
  BROADCAST
  MULTICAST
}

enum BroadcastStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model BroadcastJob {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  lineChannelId   String
  lineChannel     LineChannel     @relation(fields: [lineChannelId], references: [id])
  createdByUserId String
  createdBy       User            @relation(fields: [createdByUserId], references: [id])
  type            BroadcastType
  status          BroadcastStatus @default(PENDING)
  recipientCount  Int?
  messages        Json
  scheduledAt     DateTime?       // Null means send immediately
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([lineChannelId])
  @@index([status, scheduledAt])
  @@map("broadcast_jobs")
}

// ============================================================
// CUSTOMER & CRM
// ============================================================

model Customer {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  displayName String?   @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  email       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  conversations Conversation[]
  channels      CustomerChannel[]

  @@index([tenantId])
  @@map("customers")
}

model CustomerChannel {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customerId    String   @map("customer_id")
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channelType   String   @map("channel_type")
  channelUserId String   @map("channel_user_id")

  @@unique([channelType, channelUserId])
  @@index([tenantId])
  @@index([customerId])
  @@map("customer_channels")
}

model AiSuggestion {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  actionType     String       @default("generate") @map("action_type")
  promptUsed     String?      @map("prompt_used")
  suggestionText String?      @map("suggestion_text")
  status         String       @default("shown")
  finalSentText  String?      @map("final_sent_text")
  provider       String?
  latencyMs      Int?         @map("latency_ms")
  errorCode      String?      @map("error_code")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([provider])
  @@map("ai_suggestions")
}

model PromptTemplate {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  name         String
  systemPrompt String   @map("system_prompt")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@map("prompt_templates")
}

model AiTrainingPair {
  id               String       @id @default(uuid())
  tenantId         String       @map("tenant_id")
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  conversationId   String       @map("conversation_id")
  conversation     Conversation @relation(fields: [conversationId], references: [id])
  customerMessage  String       @map("customer_message")
  assistantReply   String       @map("assistant_reply")
  suggestionId     String?      @map("suggestion_id")
  isSuggestionUsed Boolean      @default(false) @map("is_suggestion_used")
  isEdited         Boolean      @default(false) @map("is_edited")
  status           String       @default("pending") // pending, approved, rejected
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  @@index([tenantId])
  @@index([status])
  @@map("ai_training_pairs")
}

