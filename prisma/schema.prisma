// prisma/schema.prisma
// OmniChat SaaS — Stage 1: Foundation
// Covers: Tenant, Auth, RBAC, User Management, Workspace, Invitation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  OWNER
  ADMIN
  AGENT
  QC
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  TWO_FA_ENABLED
  TWO_FA_DISABLED
  TENANT_SWITCHED
  // User
  USER_INVITED
  USER_REMOVED
  USER_ROLE_CHANGED
  // Tenant
  TENANT_CREATED
  TENANT_SETTINGS_CHANGED
  PLAN_CHANGED
  PLAN_LIMIT_EXCEEDED
  USAGE_THRESHOLD_REACHED
  // Workspace
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  // LINE OA
  LINE_CHANNEL_CONNECTED
  LINE_CHANNEL_UPDATED
  LINE_CHANNEL_DISCONNECTED
  CONVERSATION_CUSTOMER_RENAMED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_ASSIGNED
  CONVERSATION_UNASSIGNED
  CONVERSATION_PRIORITY_CHANGED
  CONVERSATION_TAG_CREATED
  CONVERSATION_TAG_UPDATED
  CONVERSATION_TAG_DELETED
  CONVERSATION_TAG_ADDED
  CONVERSATION_TAG_REMOVED
  CONVERSATION_NOTE_CREATED
  CONVERSATION_NOTE_DELETED
  SAVED_REPLY_CREATED
  SAVED_REPLY_UPDATED
  SAVED_REPLY_DELETED
  INBOX_SETTINGS_UPDATED
  LINE_MESSAGE_RECEIVED
  LINE_REPLY_SENT
  LINE_WEBHOOK_FAILED
  LINE_MARK_AS_READ
  LINE_BROADCAST_SENT
  LINE_MULTICAST_SENT
  LINE_FOLLOW_RECEIVED
  LINE_UNFOLLOW_RECEIVED
  LINE_UNSEND_RECEIVED
  LINE_BROADCAST_SCHEDULED
  // AI Suggest
  AI_SUGGEST_GENERATED
  AI_SUGGEST_SENT
  AI_SUGGEST_EDITED
  AI_SUGGEST_REJECTED
  AI_SUGGEST_FAILED
  // Knowledge Base
  KNOWLEDGE_ARTICLE_CREATED
  KNOWLEDGE_ARTICLE_UPDATED
  KNOWLEDGE_ARTICLE_DELETED
  KNOWLEDGE_DOCUMENT_CREATED
  KNOWLEDGE_DOCUMENT_DELETED
  KNOWLEDGE_DOCUMENT_INGESTED
  KNOWLEDGE_DOCUMENT_INGEST_FAILED
  KNOWLEDGE_DOCUMENT_REINDEX_REQUESTED
  // AI Scenarios
  AI_SCENARIO_CREATED
  AI_SCENARIO_UPDATED
  AI_SCENARIO_DELETED
  AI_SCENARIO_MATCHED
  // Automation
  AUTOMATION_RULE_CREATED
  AUTOMATION_RULE_UPDATED
  AUTOMATION_RULE_DELETED
  AUTOMATION_RUN_STARTED
  AUTOMATION_STEP_EXECUTED
  AUTOMATION_RUN_COMPLETED
  AUTOMATION_RUN_FAILED
  // AI Auto-Reply
  AI_AUTO_REPLY_SENT
  AI_AUTO_REPLY_SKIPPED
  AI_AUTO_REPLY_ESCALATED
  AI_AUTO_REPLY_FAILED
}

enum AutomationTriggerType {
  MESSAGE_RECEIVED
  CONVERSATION_CREATED
  TAG_ADDED
  STATUS_CHANGED
  OFF_HOURS
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  WAITING
  WAITING_FOR_REPLY
  COMPLETED
  FAILED
}

enum KnowledgeDocumentStatus {
  PENDING
  READY
  FAILED
}

enum KnowledgeDocumentSource {
  TEXT
  FILE
  URL
}

enum MessageSource {
  LINE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  STICKER
  IMAGE
  VIDEO
  AUDIO
  FILE
  UNKNOWN
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AiAgentGender {
  FEMALE
  MALE
}

enum AiAutoReplyMode {
  OFF
  WHEN_UNASSIGNED
  ALWAYS
  OFF_HOURS_ONLY
}

// ============================================================
// TENANT
// ============================================================

model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique // URL-safe identifier e.g. "acme-corp"
  logoUrl     String?
  planId      String    @default("free")
  trialEndsAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  workspaces                Workspace[]
  users                     WorkspaceMember[]
  invitations               Invitation[]
  auditLogs                 AuditLog[]
  settings                  TenantSettings?
  usageCounters             UsageCounter[]
  lineChannels              LineChannel[]
  conversations             Conversation[]
  messages                  Message[]
  conversationTags          ConversationTag[]
  conversationTagLinks      ConversationTagLink[]
  conversationInternalNotes ConversationInternalNote[]
  savedReplies              SavedReply[]
  files                     File[]
  broadcastJobs             BroadcastJob[]
  customers                 Customer[]
  customerChannels          CustomerChannel[]
  aiSuggestions             AiSuggestion[]
  promptTemplates           PromptTemplate[]
  knowledgeArticles         KnowledgeArticle[]
  knowledgeDocuments        KnowledgeDocument[]
  knowledgeChunks           KnowledgeChunk[]
  aiScenarios               AiScenario[]
  automationRules           AutomationRule[]
  automationRuns            AutomationRun[]
  aiTrainingPairs           AiTrainingPair[]

  @@index([slug])
  @@index([planId])
  @@map("tenants")
}

model PlanLimit {
  id                   String   @id @default(uuid())
  planId               String   @unique
  maxWorkspaces        Int
  maxAgents            Int
  maxAiCreditsPerMonth Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("plan_limits")
}

model TenantSettings {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  // Defaults
  defaultLanguage        String   @default("th")
  timezone               String   @default("Asia/Bangkok")
  // Feature flags (expand per stage)
  enableTwoFa            Boolean  @default(false)
  maxAgents              Int      @default(10)
  inProgressAlertMinutes Int      @default(10)
  enableAiSuggest        Boolean       @default(true)   @map("enable_ai_suggest")
  enableAiScenarios      Boolean       @default(true)   @map("enable_ai_scenarios")
  aiProvider             String        @default("gemini") @map("ai_provider")
  aiAgentGender          AiAgentGender @default(FEMALE)   @map("ai_agent_gender")
  enableAiAutoReply      Boolean         @default(false)  @map("enable_ai_auto_reply")
  aiAutoReplyMode        AiAutoReplyMode @default(OFF_HOURS_ONLY) @map("ai_auto_reply_mode")
  aiAutoReplyBusinessHourStart Int       @default(8)      @map("ai_auto_reply_business_hour_start")
  aiAutoReplyBusinessHourEnd   Int       @default(23)     @map("ai_auto_reply_business_hour_end")
  aiAutoReplyInstructions    String?   @map("ai_auto_reply_instructions")
  aiEscalationKeywords       String[]  @default([])     @map("ai_escalation_keywords")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("tenant_settings")
}

// ============================================================
// WORKSPACE
// Tenants can have multiple workspaces (e.g. departments)
// ============================================================

model Workspace {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  members       WorkspaceMember[]
  invitations   Invitation[]
  lineChannels  LineChannel[]
  conversations Conversation[]

  @@index([tenantId])
  @@map("workspaces")
}

// ============================================================
// USER (Global — not tenant-scoped)
// Identity record. Actual tenant membership via WorkspaceMember
// ============================================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String?   @unique
  passwordHash    String
  displayName     String
  avatarUrl       String?
  isSuperOwner    Boolean   @default(false)
  // 2FA
  twoFaSecret     String? // encrypted AES-256
  twoFaEnabled    Boolean   @default(false)
  // Security
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relations
  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  sentInvitations Invitation[]      @relation("InvitedBy")
  auditLogs       AuditLog[]
  savedReplies    SavedReply[]
  broadcastJobs   BroadcastJob[]

  @@map("users")
}

// ============================================================
// WORKSPACE MEMBER
// Join table: User <-> Workspace with Role
// ============================================================

model WorkspaceMember {
  id          String    @id @default(uuid())
  tenantId    String // denormalized for easy filtering
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  role        Role      @default(AGENT)
  isActive    Boolean   @default(true)
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignedConversations Conversation[]             @relation("AssignedConversations")
  internalNotes         ConversationInternalNote[]

  @@unique([workspaceId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("workspace_members")
}

// ============================================================
// INVITATION
// ============================================================

model Invitation {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  invitedByUserId String
  invitedBy       User             @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  email           String
  role            Role             @default(AGENT)
  token           String           @unique // secure random token, emailed to invitee
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([invitedByUserId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}

// ============================================================
// REFRESH TOKEN
// ============================================================

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique // store hash only, never raw token
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// AUDIT LOG (Stage 1 — basic auth/user events)
// Immutable: never delete, never update
// ============================================================

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  targetType String? // e.g. "User", "Conversation"
  targetId   String? // ID of the affected resource
  metadata   Json? // extra context (IP, user agent, old/new values)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model UsageCounter {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  metric      String
  periodStart DateTime
  periodEnd   DateTime
  value       BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, metric, periodStart])
  @@index([tenantId])
  @@map("usage_counters")
}

model LineChannel {
  id                          String    @id @default(uuid())
  tenantId                    String
  tenant                      Tenant    @relation(fields: [tenantId], references: [id])
  workspaceId                 String
  workspace                   Workspace @relation(fields: [workspaceId], references: [id])
  name                        String
  badgeColor                  String    @default("#4f46e5")
  lineChannelId               String
  encryptedChannelSecret      String
  encryptedChannelAccessToken String
  tokenExpiresAt              DateTime?
  isActive                    Boolean   @default(true)
  lastWebhookAt               DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  deletedAt                   DateTime?

  conversations Conversation[]
  messages      Message[]
  savedReplies       SavedReply[]
  broadcastJobs      BroadcastJob[]
  knowledgeArticles  KnowledgeArticle[]
  knowledgeDocuments KnowledgeDocument[]
  aiScenarios        AiScenario[]
  automationRules    AutomationRule[]

  @@unique([tenantId, lineChannelId])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([lineChannelId])
  @@map("line_channels")
}

model Conversation {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  workspaceId         String
  workspace           Workspace            @relation(fields: [workspaceId], references: [id])
  lineChannelId       String
  lineChannel         LineChannel          @relation(fields: [lineChannelId], references: [id])
  source              MessageSource        @default(LINE)
  externalThreadId    String
  displayName         String?
  pictureUrl          String?
  nickname            String?
  status              String               @default("OPEN")
  priority            ConversationPriority @default(NORMAL)
  assignedToMemberId  String?
  assignedToMember    WorkspaceMember?     @relation("AssignedConversations", fields: [assignedToMemberId], references: [id])
  inProgressStartedAt DateTime?
  lastMessageAt       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  customerId          String?              @map("customer_id")
  customer            Customer?            @relation(fields: [customerId], references: [id])

  messages      Message[]
  tagLinks      ConversationTagLink[]
  internalNotes ConversationInternalNote[]
  files         File[]
  aiSuggestions AiSuggestion[]
  automationRuns AutomationRun[]
  aiTrainingPairs AiTrainingPair[]

  @@unique([tenantId, source, lineChannelId, externalThreadId])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([lineChannelId])
  @@index([assignedToMemberId])
  @@index([priority])
  @@index([lastMessageAt])
  @@index([tenantId, deletedAt, lastMessageAt])
  @@index([tenantId, status, deletedAt, lastMessageAt])
  @@index([tenantId, assignedToMemberId, deletedAt, lastMessageAt])
  @@map("conversations")
}

model ConversationTag {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  color     String    @default("#64748b")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conversations ConversationTagLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("conversation_tags")
}

model ConversationTagLink {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  tagId          String
  tag            ConversationTag @relation(fields: [tagId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([conversationId, tagId])
  @@index([tenantId])
  @@index([tagId])
  @@map("conversation_tag_links")
}

model ConversationInternalNote {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  authorMemberId String
  authorMember   WorkspaceMember @relation(fields: [authorMemberId], references: [id])
  body           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([conversationId])
  @@index([authorMemberId])
  @@map("conversation_internal_notes")
}

model SavedReply {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  lineChannelId String?
  lineChannel   LineChannel? @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  title         String
  body          String
  shortcutKey   String?
  imageUrl      String?
  hotkeyBinding String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId, userId, shortcutKey])
  @@index([tenantId])
  @@index([tenantId, lineChannelId])
  @@map("saved_replies")
}

model KnowledgeArticle {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  lineChannelId String?
  lineChannel   LineChannel? @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  title         String
  content       String
  keywords      String[]     @default([])
  category      String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, lineChannelId])
  @@map("knowledge_articles")
}

model KnowledgeDocument {
  id            String                  @id @default(uuid())
  tenantId      String
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  lineChannelId String?
  lineChannel   LineChannel?            @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  title         String
  sourceType    KnowledgeDocumentSource @default(TEXT)
  mimeType      String?
  storageKey    String?
  sourceUrl     String?
  rawText       String
  status        KnowledgeDocumentStatus @default(PENDING)
  errorMessage  String?
  chunkCount    Int                     @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?
  chunks        KnowledgeChunk[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, lineChannelId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String            @id @default(uuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String
  embedding  Json?
  createdAt  DateTime          @default(now())

  @@unique([documentId, chunkIndex])
  @@index([tenantId])
  @@index([documentId])
  @@map("knowledge_chunks")
}

model AiScenario {
  id                   String                @id @default(uuid())
  tenantId             String
  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  lineChannelId        String?
  lineChannel          LineChannel?          @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  name                 String
  priority             Int                   @default(100)
  isEnabled            Boolean               @default(true)
  triggerKeywords      String[]              @default([])
  triggerTagNames      String[]              @default([])
  activeHourStart      Int?
  activeHourEnd        Int?
  instructions         String
  actionAddTagName     String?
  actionAssignMemberId String?
  actionSetPriority    ConversationPriority?
  actionEscalate       Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?

  @@index([tenantId])
  @@index([tenantId, isEnabled])
  @@index([tenantId, lineChannelId])
  @@map("ai_scenarios")
}

model AutomationRule {
  id                String                 @id @default(uuid())
  tenantId          String
  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  lineChannelId     String?
  lineChannel       LineChannel?           @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  name              String
  priority          Int                    @default(100)
  isEnabled         Boolean                @default(true)
  triggerType       AutomationTriggerType
  triggerKeywords   String[]               @default([])
  triggerTagNames   String[]               @default([])
  triggerStatus     String?
  offHourStart      Int?
  offHourEnd        Int?
  steps             Json
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?

  runs AutomationRun[]

  @@index([tenantId])
  @@index([tenantId, isEnabled])
  @@index([tenantId, triggerType])
  @@index([tenantId, lineChannelId])
  @@map("automation_rules")
}

model AutomationRun {
  id               String              @id @default(uuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  ruleId           String
  rule             AutomationRule      @relation(fields: [ruleId], references: [id])
  conversationId   String
  conversation     Conversation        @relation(fields: [conversationId], references: [id])
  status           AutomationRunStatus @default(PENDING)
  currentStepIndex Int                 @default(0)
  context          Json?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([tenantId])
  @@index([tenantId, conversationId])
  @@index([tenantId, ruleId])
  @@index([status])
  @@map("automation_runs")
}

model Message {
  id                String           @id @default(uuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  conversationId    String
  conversation      Conversation     @relation(fields: [conversationId], references: [id])
  lineChannelId     String
  lineChannel       LineChannel      @relation(fields: [lineChannelId], references: [id])
  direction         MessageDirection
  source            MessageSource    @default(LINE)
  type              MessageType      @default(TEXT)
  externalMessageId String?
  markAsReadToken   String?
  text              String?
  rawPayload        Json?
  sentAt            DateTime?
  mediaUrl          String?   // R2 public/signed URL
  mediaMimeType     String?
  mediaSize         Int?
  mediaR2Key        String?   // R2 object key
  mediaFileName     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@unique([lineChannelId, externalMessageId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([lineChannelId])
  @@index([createdAt])
  @@index([tenantId, conversationId, deletedAt, createdAt])
  @@map("messages")
}

model File {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  conversationId  String?
  conversation    Conversation?  @relation(fields: [conversationId], references: [id])
  fileName        String
  fileType        FileType       // IMAGE, AUDIO, VIDEO, DOCUMENT
  mimeType        String         // "image/jpeg", "audio/mp4", etc.
  fileSize        Int            // bytes
  r2Key           String         // "temporary/tenant-001/images/2026/06/17/abc.jpg"
  publicUrl       String?        // signed URL or public URL
  retentionType   RetentionType  // PERMANENT or TEMPORARY
  expiresAt       DateTime?      // NULL for permanent, createdAt+7d for temporary
  createdAt       DateTime       @default(now())
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([expiresAt])
  @@index([retentionType, expiresAt])
  @@map("files")
}

enum FileType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

enum RetentionType {
  PERMANENT
  TEMPORARY
}

