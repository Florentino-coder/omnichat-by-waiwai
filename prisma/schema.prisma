// prisma/schema.prisma
// OmniChat SaaS — Stage 1: Foundation
// Covers: Tenant, Auth, RBAC, User Management, Workspace, Invitation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  OWNER
  ADMIN
  AGENT
  QC
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  TWO_FA_ENABLED
  TWO_FA_DISABLED
  // User
  USER_INVITED
  USER_REMOVED
  USER_ROLE_CHANGED
  // Tenant
  TENANT_CREATED
  TENANT_SETTINGS_CHANGED
  PLAN_CHANGED
  PLAN_LIMIT_EXCEEDED
  USAGE_THRESHOLD_REACHED
  // Workspace
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  // LINE OA
  LINE_CHANNEL_CONNECTED
  LINE_CHANNEL_UPDATED
  LINE_CHANNEL_DISCONNECTED
  CONVERSATION_CUSTOMER_RENAMED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_ASSIGNED
  CONVERSATION_UNASSIGNED
  CONVERSATION_PRIORITY_CHANGED
  CONVERSATION_TAG_CREATED
  CONVERSATION_TAG_UPDATED
  CONVERSATION_TAG_DELETED
  CONVERSATION_TAG_ADDED
  CONVERSATION_TAG_REMOVED
  CONVERSATION_NOTE_CREATED
  CONVERSATION_NOTE_DELETED
  SAVED_REPLY_CREATED
  SAVED_REPLY_UPDATED
  SAVED_REPLY_DELETED
  INBOX_SETTINGS_UPDATED
  LINE_MESSAGE_RECEIVED
  LINE_REPLY_SENT
  LINE_WEBHOOK_FAILED
}

enum MessageSource {
  LINE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  STICKER
  UNKNOWN
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================================
// TENANT
// ============================================================

model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique // URL-safe identifier e.g. "acme-corp"
  logoUrl     String?
  planId      String    @default("free")
  trialEndsAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  workspaces                Workspace[]
  users                     WorkspaceMember[]
  invitations               Invitation[]
  auditLogs                 AuditLog[]
  settings                  TenantSettings?
  usageCounters             UsageCounter[]
  lineChannels              LineChannel[]
  conversations             Conversation[]
  messages                  Message[]
  conversationTags          ConversationTag[]
  conversationTagLinks      ConversationTagLink[]
  conversationInternalNotes ConversationInternalNote[]
  savedReplies              SavedReply[]

  @@index([slug])
  @@index([planId])
  @@map("tenants")
}

model PlanLimit {
  id                   String   @id @default(uuid())
  planId               String   @unique
  maxWorkspaces        Int
  maxAgents            Int
  maxAiCreditsPerMonth Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("plan_limits")
}

model TenantSettings {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  // Defaults
  defaultLanguage        String   @default("th")
  timezone               String   @default("Asia/Bangkok")
  // Feature flags (expand per stage)
  enableTwoFa            Boolean  @default(false)
  maxAgents              Int      @default(10)
  inProgressAlertMinutes Int      @default(10)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("tenant_settings")
}

// ============================================================
// WORKSPACE
// Tenants can have multiple workspaces (e.g. departments)
// ============================================================

model Workspace {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  members       WorkspaceMember[]
  invitations   Invitation[]
  lineChannels  LineChannel[]
  conversations Conversation[]

  @@index([tenantId])
  @@map("workspaces")
}

// ============================================================
// USER (Global — not tenant-scoped)
// Identity record. Actual tenant membership via WorkspaceMember
// ============================================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  displayName     String
  avatarUrl       String?
  // 2FA
  twoFaSecret     String? // encrypted AES-256
  twoFaEnabled    Boolean   @default(false)
  // Security
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relations
  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  sentInvitations Invitation[]      @relation("InvitedBy")
  auditLogs       AuditLog[]

  @@map("users")
}

// ============================================================
// WORKSPACE MEMBER
// Join table: User <-> Workspace with Role
// ============================================================

model WorkspaceMember {
  id          String    @id @default(uuid())
  tenantId    String // denormalized for easy filtering
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  role        Role      @default(AGENT)
  isActive    Boolean   @default(true)
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignedConversations Conversation[]             @relation("AssignedConversations")
  internalNotes         ConversationInternalNote[]

  @@unique([workspaceId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("workspace_members")
}

// ============================================================
// INVITATION
// ============================================================

model Invitation {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  invitedByUserId String
  invitedBy       User             @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  email           String
  role            Role             @default(AGENT)
  token           String           @unique // secure random token, emailed to invitee
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([invitedByUserId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}

// ============================================================
// REFRESH TOKEN
// ============================================================

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique // store hash only, never raw token
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// AUDIT LOG (Stage 1 — basic auth/user events)
// Immutable: never delete, never update
// ============================================================

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  targetType String? // e.g. "User", "Conversation"
  targetId   String? // ID of the affected resource
  metadata   Json? // extra context (IP, user agent, old/new values)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model UsageCounter {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  metric      String
  periodStart DateTime
  periodEnd   DateTime
  value       BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, metric, periodStart])
  @@index([tenantId])
  @@map("usage_counters")
}

model LineChannel {
  id                          String    @id @default(uuid())
  tenantId                    String
  tenant                      Tenant    @relation(fields: [tenantId], references: [id])
  workspaceId                 String
  workspace                   Workspace @relation(fields: [workspaceId], references: [id])
  name                        String
  badgeColor                  String    @default("#4f46e5")
  lineChannelId               String
  encryptedChannelSecret      String
  encryptedChannelAccessToken String
  tokenExpiresAt              DateTime?
  isActive                    Boolean   @default(true)
  lastWebhookAt               DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  deletedAt                   DateTime?

  conversations Conversation[]
  messages      Message[]
  savedReplies  SavedReply[]

  @@unique([tenantId, lineChannelId])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([lineChannelId])
  @@map("line_channels")
}

model Conversation {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  workspaceId         String
  workspace           Workspace            @relation(fields: [workspaceId], references: [id])
  lineChannelId       String
  lineChannel         LineChannel          @relation(fields: [lineChannelId], references: [id])
  source              MessageSource        @default(LINE)
  externalThreadId    String
  displayName         String?
  nickname            String?
  status              String               @default("OPEN")
  priority            ConversationPriority @default(NORMAL)
  assignedToMemberId  String?
  assignedToMember    WorkspaceMember?     @relation("AssignedConversations", fields: [assignedToMemberId], references: [id])
  inProgressStartedAt DateTime?
  lastMessageAt       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  messages      Message[]
  tagLinks      ConversationTagLink[]
  internalNotes ConversationInternalNote[]

  @@unique([tenantId, source, lineChannelId, externalThreadId])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([lineChannelId])
  @@index([assignedToMemberId])
  @@index([priority])
  @@index([lastMessageAt])
  @@index([tenantId, deletedAt, lastMessageAt])
  @@index([tenantId, status, deletedAt, lastMessageAt])
  @@index([tenantId, assignedToMemberId, deletedAt, lastMessageAt])
  @@map("conversations")
}

model ConversationTag {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  color     String    @default("#64748b")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conversations ConversationTagLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("conversation_tags")
}

model ConversationTagLink {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  tagId          String
  tag            ConversationTag @relation(fields: [tagId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([conversationId, tagId])
  @@index([tenantId])
  @@index([tagId])
  @@map("conversation_tag_links")
}

model ConversationInternalNote {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  authorMemberId String
  authorMember   WorkspaceMember @relation(fields: [authorMemberId], references: [id])
  body           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([conversationId])
  @@index([authorMemberId])
  @@map("conversation_internal_notes")
}

model SavedReply {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  lineChannelId String?
  lineChannel   LineChannel? @relation(fields: [lineChannelId], references: [id], onDelete: SetNull)
  title         String
  body          String
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([tenantId, lineChannelId])
  @@map("saved_replies")
}

model Message {
  id                String           @id @default(uuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  conversationId    String
  conversation      Conversation     @relation(fields: [conversationId], references: [id])
  lineChannelId     String
  lineChannel       LineChannel      @relation(fields: [lineChannelId], references: [id])
  direction         MessageDirection
  source            MessageSource    @default(LINE)
  type              MessageType      @default(TEXT)
  externalMessageId String?
  text              String?
  rawPayload        Json?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@unique([lineChannelId, externalMessageId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([lineChannelId])
  @@index([createdAt])
  @@index([tenantId, conversationId, deletedAt, createdAt])
  @@map("messages")
}

